---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/urls.mjs";
import { searchDocuments } from "../lib/search-index.mjs";

const basePath = import.meta.env.BASE_URL;
---

<BaseLayout title="Search | Hortsoc.org" description="Search the Horticultural Society website.">
  <section class="search-page page-shell">
    <header class="search-header">
      <h1>Search</h1>
      <p>Search pages, blog posts, gallery sections, and society information across the site.</p>
      <form class="search-form" role="search" action={withBase("/search/", basePath)} method="get">
        <label>
          <span class="sr-only">Search the website</span>
          <input id="site-search-input" type="search" name="q" placeholder="Search …" />
        </label>
        <button type="submit">Search</button>
      </form>
    </header>

    <section class="search-results" aria-live="polite">
      <p id="search-status">Enter a search term to browse the site.</p>
      <div id="search-results-list"></div>
    </section>
  </section>

  <script type="application/json" id="search-index-data" data-base={basePath} set:html={JSON.stringify(searchDocuments)} />
  <script is:inline>
    (() => {
      const input = document.getElementById("site-search-input");
      const status = document.getElementById("search-status");
      const list = document.getElementById("search-results-list");
      const dataNode = document.getElementById("search-index-data");
      const documents = JSON.parse(dataNode?.textContent ?? "[]");
      const siteBase = normalizeBasePath(dataNode?.dataset.base ?? "/");
      const params = new URLSearchParams(window.location.search);
      const query = (params.get("q") ?? "").trim();

      if (input) {
        input.value = query;
      }

      render(query);

      function render(term) {
        list.innerHTML = "";

        if (!term) {
          status.textContent = "Enter a search term to browse the site.";
          return;
        }

        const normalized = term.toLowerCase();
        const results = documents.filter((document) => {
          const haystack = `${document.title} ${document.body} ${document.keywords}`.toLowerCase();
          return haystack.includes(normalized);
        });

        status.textContent = results.length === 0
          ? `No results found for “${term}”.`
          : `${results.length} result${results.length === 1 ? "" : "s"} found for “${term}”.`;

        results.forEach((result) => {
          const article = document.createElement("article");
          article.className = "search-result";
          const resultHref = toSitePath(result.path);

          const heading = document.createElement("h2");
          const link = document.createElement("a");
          link.href = resultHref;
          link.textContent = result.title;
          heading.appendChild(link);

          const meta = document.createElement("p");
          meta.className = "search-result-path";
          meta.textContent = resultHref;

          const excerpt = document.createElement("p");
          excerpt.className = "search-result-snippet";
          excerpt.innerHTML = buildSnippet(result, term);

          article.appendChild(heading);
          article.appendChild(meta);
          article.appendChild(excerpt);
          list.appendChild(article);
        });
      }

      function buildSnippet(result, term) {
        const normalized = term.toLowerCase();
        const sourceText = `${result.body} ${result.keywords}`.trim();
        const text = sourceText || result.excerpt || "";
        const matchIndex = text.toLowerCase().indexOf(normalized);

        if (matchIndex < 0) {
          return escapeHtml(result.excerpt || text);
        }

        const contextRadius = 95;
        const snippetStart = Math.max(0, matchIndex - contextRadius);
        const snippetEnd = Math.min(text.length, matchIndex + term.length + contextRadius);
        let snippet = text.slice(snippetStart, snippetEnd).trim();

        if (snippetStart > 0) {
          snippet = `…${snippet}`;
        }

        if (snippetEnd < text.length) {
          snippet = `${snippet}…`;
        }

        const escapedSnippet = escapeHtml(snippet);
        const highlightedPattern = new RegExp(`(${escapeRegExp(term)})`, "ig");
        return escapedSnippet.replace(highlightedPattern, "<strong>$1</strong>");
      }

      function escapeHtml(text) {
        return text
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/\"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function escapeRegExp(text) {
        return text.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
      }

      function normalizeBasePath(value) {
        if (!value || value === "/") {
          return "/";
        }

        return value.endsWith("/") ? value.slice(0, -1) : value;
      }

      function toSitePath(pathname) {
        if (typeof pathname !== "string" || !pathname.startsWith("/") || pathname.startsWith("//")) {
          return pathname;
        }

        return siteBase === "/" ? pathname : pathname === "/" ? `${siteBase}/` : `${siteBase}${pathname}`;
      }
    })();
  </script>

  <style>
    .search-page {
      display: grid;
      gap: 2rem;
      padding: var(--page-shell-padding);
      background: #fff;
      box-sizing: border-box;
    }

    .search-header {
      display: grid;
      gap: 1rem;
      max-width: 50rem;
    }

    .search-header h1,
    .search-header p {
      margin: 0;
    }

    .search-form {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .search-form label {
      flex: 1 1 20rem;
    }

    .search-form input,
    .search-form button {
      font: inherit;
    }

    .search-form input {
      width: 100%;
      box-sizing: border-box;
      padding: 0.7rem 0.85rem;
      border: 1px solid rgba(120, 120, 120, 0.24);
      background: #fff;
      color: var(--page-copy-color);
    }

    .search-form button {
      padding: 0.7rem 1rem;
      border: 1px solid rgba(120, 120, 120, 0.24);
      background: #fff;
      color: #666;
      cursor: pointer;
    }

    .search-results {
      display: grid;
      gap: 1.25rem;
      max-width: 56rem;
    }

    .search-results > p {
      margin: 0;
      color: var(--page-muted-color);
    }

    #search-results-list {
      display: grid;
      gap: 1rem;
    }

    .search-result {
      display: grid;
      gap: 0.4rem;
      padding: 1rem 0;
      border-top: 1px solid rgba(120, 120, 120, 0.16);
    }

    .search-result h2,
    .search-result p {
      margin: 0;
    }

    .search-result h2 a {
      color: var(--page-heading-color);
      text-decoration: none;
    }

    .search-result h2 a:hover,
    .search-result h2 a:focus-visible {
      text-decoration: underline;
    }

    .search-result-path {
      font-family: var(--font-ui);
      font-size: 0.92rem;
      color: var(--page-muted-color);
    }

    .search-result-snippet strong {
      font-weight: 700;
      color: var(--page-heading-color);
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  </style>
</BaseLayout>
