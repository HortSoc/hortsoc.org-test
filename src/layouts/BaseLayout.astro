---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { withoutBase } from "../lib/urls.mjs";

const { title = "Hortsoc.org", description = "Static site scaffold for the migrated Hortsoc.org routes." } = Astro.props;
const currentPath = withoutBase(Astro.url.pathname, import.meta.env.BASE_URL);
const normalizedPath = currentPath.endsWith("/") ? currentPath : `${currentPath}/`;
const isHome = currentPath === "/";
const isEditorial = ["/about/", "/membership/", "/whats-on/"].includes(normalizedPath);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Alegreya+Sans:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color-scheme: light;
        --font-body: Georgia, "Times New Roman", serif;
        --font-ui: "Alegreya Sans", "Trebuchet MS", "Gill Sans", Arial, sans-serif;
        --site-frame-width: min(75rem, calc(100% - 2rem));
        --site-inner-padding: clamp(0.9rem, 2vw, 1.35rem);
        --site-block-gap: clamp(1.35rem, 2vw, 1.75rem);
        --site-column-gap: clamp(1rem, 1.8vw, 1.55rem);
        --site-outer-background: #f0f0f0;
        --site-frame-border: #c6c6c6;
        --site-nav-green: #a7c936;
        --site-nav-text: #444444;
        --site-nav-accent: #607518;
        --page-shell-width: min(68rem, calc(100% - 5rem));
        --page-copy-width: 58rem;
        --page-shell-padding: clamp(1.5rem, 4vw, 3rem);
        --page-block-gap: clamp(1.4rem, 2vw, 1.9rem);
        --page-heading-color: #4d4d4d;
        --page-copy-color: #4f4f4f;
        --page-muted-color: #5f5f5f;
        background: var(--site-outer-background);
        color: #203021;
        --color-background: var(--site-outer-background);
        --color-surface: rgba(255, 252, 247, 0.9);
        --color-surface-strong: rgba(255, 252, 247, 0.97);
        --color-border: rgba(53, 82, 39, 0.16);
        --color-text: #303030;
        --color-muted: #5e5e5e;
        --color-accent: #607518;
        --color-footer: #3d5627;
      }

      html {
        font-family: var(--font-body);
        background: var(--site-outer-background);
        color: var(--color-text);
      }

      body {
        margin: 0;
        background: var(--site-outer-background);
      }

      .site-shell {
        min-height: 100vh;
        display: grid;
        grid-template-rows: auto 1fr auto;
        position: relative;
      }

      .site-shell::before,
      .site-shell::after {
        content: "";
        position: absolute;
        top: 0;
        bottom: 0;
        width: 1px;
        background: var(--site-frame-border);
        pointer-events: none;
        z-index: 0;
      }

      .site-shell::before {
        left: calc((100% - var(--site-frame-width)) / 2);
      }

      .site-shell::after {
        right: calc((100% - var(--site-frame-width)) / 2);
      }

      .site-shell > * {
        position: relative;
        z-index: 1;
      }

      main {
        width: var(--site-frame-width);
        margin: 0 auto;
        padding: 1.1rem 0 4rem;
        background: #ffffff;
      }

      main.home {
        padding-top: 0;
        background: #ffffff;
      }

      main.editorial {
        padding-top: 0;
      }

      .page-stack {
        display: grid;
        gap: 1.6rem;
      }

      main.home .page-stack {
        gap: 0;
      }

      main.editorial .page-stack {
        gap: 0;
      }

      h1,
      h2,
      h3 {
        line-height: 1.1;
      }

      p,
      li,
      dd {
        line-height: 1.6;
        color: var(--color-text);
      }

      a {
        color: var(--color-accent);
      }

      .panel {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 1.15rem;
        padding: 1.2rem 1.35rem;
        box-shadow: 0 18px 40px rgba(44, 54, 35, 0.08);
      }

      :global(.page-shell) {
        width: var(--page-shell-width);
        margin: 0 auto;
      }

      :global(.page-content) {
        font-family: var(--font-ui);
        color: var(--page-copy-color);
      }

      :global(.page-content p),
      :global(.page-content li),
      :global(.page-content dd) {
        margin: 0 0 1.55rem;
        font-size: 1rem;
        line-height: 1.65;
        color: var(--page-copy-color);
      }

      :global(.page-content ul),
      :global(.page-content ol) {
        margin: 0 0 1.55rem 1.35rem;
        padding: 0;
      }

      :global(.page-content li) {
        margin-bottom: 0.35rem;
      }

      :global(.page-content h1),
      :global(.page-content h2),
      :global(.page-content h3) {
        font-family: var(--font-ui);
      }

      :global(.page-content h1),
      :global(.page-content h2:first-child) {
        margin-top: 0;
      }

      :global(.page-content h2) {
        margin: 0 0 1.6rem;
        font-size: clamp(1.75rem, 3vw, 2.45rem);
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: var(--page-heading-color);
      }

      :global(.page-content h3) {
        margin: 0 0 2.05rem;
        font-size: clamp(1.2rem, 2vw, 1.6rem);
        font-weight: 400;
        line-height: 1.2;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        color: var(--page-muted-color);
      }

      :global(.page-content blockquote) {
        margin: 0 0 1.8rem 2.4rem;
        padding: 0;
        border: 0;
      }

      :global(.page-content blockquote p) {
        font-size: clamp(1.15rem, 1.8vw, 1.4rem);
        line-height: 1.25;
        font-style: italic;
        color: #505050;
      }

      :global(.page-content img) {
        display: block;
        max-width: 100%;
        height: auto;
        margin: 1rem auto;
      }

      :global(.page-content hr) {
        border: 0;
        border-top: 1px solid rgba(71, 94, 49, 0.18);
        margin: 1.8rem 0;
      }

      footer {
        background: transparent;
      }

      @media (max-width: 56rem) {
        :global(.page-shell) {
          width: calc(100% - 2rem);
        }

        :global(.page-content blockquote) {
          margin-left: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-shell">
      <SiteHeader currentPath={currentPath} />
      <main class:list={{ home: isHome, editorial: isEditorial }}>
        <div class="page-stack">
          <slot />
        </div>
      </main>
      <SiteFooter />
    </div>
  </body>
 </html>
