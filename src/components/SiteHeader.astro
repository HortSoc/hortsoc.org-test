---
import { primaryNavigation } from "../content/site-navigation.mjs";
import { siteAssetPlan, siteBrand } from "../content/site-assets.mjs";
import { withBase } from "../lib/urls.mjs";
import SiteNavigation from "./SiteNavigation.astro";

const { currentPath = "/" } = Astro.props;
const basePath = import.meta.env.BASE_URL;
---

<header class="site-header">
  <div class="masthead-band">
    <div class="masthead-inner">
      <a class="brand-link" href={withBase("/", basePath)} aria-label={siteBrand.name}>
        <img
          class="masthead-image"
          src={withBase(siteAssetPlan.masthead_banner.current_path, basePath)}
          alt={siteAssetPlan.masthead_banner.alt}
        />
      </a>
    </div>
  </div>

  <div class="nav-band">
    <div class="nav-inner">
      <SiteNavigation items={primaryNavigation} currentPath={currentPath} />
    </div>
  </div>
</header>

<style>
  .masthead-band {
    background: transparent;
  }

  .masthead-inner,
  .nav-inner {
    width: var(--site-frame-width);
    margin: 0 auto;
  }

  .masthead-inner {
    display: flex;
    justify-content: center;
    background: #ffffff;
    border-bottom: 1px solid rgba(120, 120, 120, 0.12);
    padding: 2.8rem 0 2.2rem;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .masthead-image {
    display: block;
    width: min(23rem, 100%);
    height: auto;
    margin: 0 auto;
    object-fit: contain;
    filter: drop-shadow(0 4px 10px rgba(55, 70, 43, 0.06));
  }

  .nav-band {
    background: transparent;
  }

  .nav-inner {
    background: var(--site-nav-green);
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    border-bottom: 1px solid rgba(124, 145, 50, 0.4);
  }

  @media (max-width: 40rem) {
    .masthead-inner {
      padding: 2rem 0 1.45rem;
    }

    .masthead-image {
      width: min(17.25rem, calc(100% - 1.5rem));
    }
  }
</style>
