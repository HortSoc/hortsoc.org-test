---
import { siteAssetPlan } from "../content/site-assets.mjs";
import { withBase } from "../lib/urls.mjs";

const { Content } = Astro.props;
const basePath = import.meta.env.BASE_URL;
---

<section class="home-banner">
  <img
    class="home-banner-image"
    src={withBase(siteAssetPlan.home_hero.current_path, basePath)}
    alt={siteAssetPlan.home_hero.alt}
  />

  <div class="home-banner-overlay">
    <div class="home-banner-copy">
      <Content />
    </div>
  </div>
</section>

<style>
  .home-banner {
    position: relative;
    overflow: hidden;
    margin: 0;
    background: #d8d3c2;
  }

  .home-banner-image {
    display: block;
    width: 100%;
    aspect-ratio: 1180 / 610;
    object-fit: cover;
  }

  .home-banner-overlay {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 0.8rem 1rem 1rem;
    background: linear-gradient(180deg, rgba(41, 55, 29, 0.16), rgba(41, 55, 29, 0.06));
  }

  .home-banner-copy {
    width: min(39rem, calc(100% - 2rem));
    background: rgba(255, 252, 247, 0.84);
    padding: 1rem 1.2rem;
    box-shadow: 0 8px 18px rgba(37, 48, 26, 0.14);
  }

  .home-banner-copy :global(h1),
  .home-banner-copy :global(h2),
  .home-banner-copy :global(h3),
  .home-banner-copy :global(h4),
  .home-banner-copy :global(h5) {
    margin-top: 0;
    margin-bottom: 0.6rem;
    text-align: center;
    color: #314b29;
  }

  .home-banner-copy :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 42rem) {
    .home-banner {
      min-height: 31rem;
    }

    .home-banner-image {
      height: 31rem;
      aspect-ratio: auto;
    }

    .home-banner-overlay {
      place-items: center;
      padding-top: 1.25rem;
      padding-bottom: 1.25rem;
    }

    .home-banner-copy {
      width: calc(100% - 1.5rem);
      padding: 0.85rem 1rem;
      transform: translateY(-3%);
    }
  }
</style>
