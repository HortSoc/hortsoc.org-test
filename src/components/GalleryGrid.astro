---
import { withBase } from "../lib/urls.mjs";

const { sections = [] } = Astro.props;
const basePath = import.meta.env.BASE_URL;
---

{
  sections.map((section) => (
    <section class="gallery-page">
      <section class="panel gallery-section">
        {sections.length > 1 ? (
          <header class="section-heading">
            <h2>{section.title}</h2>
            {section.summary ? <p>{section.summary}</p> : null}
          </header>
        ) : null}
        {section.groups.map((group) => (
          <section class="group-block">
            {section.groups.length > 1 || group.title !== section.title ? <h3>{group.title}</h3> : null}

            <div class="gallery-grid">
                {group.items.map((item) => (
                  <article class="gallery-card">
                    <a href={withBase(item.image_url, basePath)}>
                      <img src={withBase(item.image_url, basePath)} alt={item.caption ?? `${section.title} image ${item.title}`} loading="lazy" />
                    </a>
                    {item.caption ? <p>{item.caption}</p> : null}
                  </article>
              ))}
            </div>
          </section>
        ))}
      </section>
    </section>
  ))
}

<style>
  .gallery-page {
    display: grid;
    gap: 1.5rem;
  }

  .gallery-section {
    display: grid;
    gap: 1.5rem;
  }

  .section-heading {
    display: grid;
    gap: 0.5rem;
  }

  .section-heading h2,
  .section-heading p {
    margin: 0;
  }

  .group-block {
    display: grid;
    gap: 1rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: 1rem;
  }

  .gallery-card {
    background: rgba(255, 251, 244, 0.94);
    border: 1px solid rgba(35, 75, 41, 0.14);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 16px 32px rgba(49, 60, 33, 0.08);
  }

  .gallery-card a {
    display: block;
  }

  .gallery-card img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    background: rgba(35, 75, 41, 0.08);
  }

  .gallery-card p {
    margin: 0;
    padding-inline: 0.9rem;
  }

  .gallery-card p {
    padding-top: 0.75rem;
    padding-bottom: 0.9rem;
  }
</style>
