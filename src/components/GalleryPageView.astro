---
import GallerySectionView from "./GallerySectionView.astro";
import PageHero from "./PageHero.astro";

const { page, Content, sections = [] } = Astro.props;
---

<>
  <PageHero title={page.title} />
  <article class="panel content-body page-content page-shell">
    <Content />
  </article>
  {sections.length > 0 ? <GallerySectionView sections={sections} /> : null}
</>

<style>
  .content-body {
    padding: var(--page-shell-padding);
    box-sizing: border-box;
    background: #ffffff;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }
</style>
