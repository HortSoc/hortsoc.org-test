---
import { withBase } from "../lib/urls.mjs";
import BlogSidebar from "./BlogSidebar.astro";
import { blogPosts, formatBlogDate, getBlogSidebarData } from "../content/blog-posts.mjs";

const {
  page,
  Content,
  posts = blogPosts,
  heading = page.title,
  intro = null,
  activeCategory = null,
  activeArchive = null,
} = Astro.props;
const blogSidebarData = getBlogSidebarData();
const basePath = import.meta.env.BASE_URL;
---

<section class="blog-layout page-shell">
  <div class="blog-main">
    <header class="blog-index-header">
      <h1>{heading}</h1>
      {
        Content ? (
          <div class="blog-intro page-content">
            <Content />
          </div>
        ) : intro ? (
          <div class="blog-intro page-content">
            <p>{intro}</p>
          </div>
        ) : null
      }
    </header>

    <div class="blog-index-list">
      {posts.map((post) => (
        <article class="blog-card">
          {post.featuredImage ? (
            <a class="blog-card-image" href={withBase(post.path, basePath)}>
              <img src={withBase(post.featuredImage.src, basePath)} alt={post.featuredImage.alt} loading="lazy" />
            </a>
          ) : null}
          <div class="blog-card-copy">
            <p class="blog-card-date">{formatBlogDate(post.dateObject)}</p>
            <h2>
              <a href={withBase(post.path, basePath)}>{post.title}</a>
            </h2>
            <p>{post.excerpt}</p>
            <a class="read-more" href={withBase(post.path, basePath)}>Read more →</a>
          </div>
        </article>
      ))}
    </div>
  </div>

  <BlogSidebar
    categories={blogSidebarData.categories}
    recentPosts={blogSidebarData.recentPosts}
    archives={blogSidebarData.archives}
    activeCategory={activeCategory}
    activeArchive={activeArchive}
  />
</section>

<style>
  .blog-layout {
    display: grid;
    grid-template-columns: minmax(0, 2.1fr) minmax(16rem, 0.9fr);
    gap: 3.5rem;
    padding: var(--page-shell-padding);
    box-sizing: border-box;
    background: #ffffff;
  }

  .blog-main {
    display: grid;
    gap: 2.5rem;
    min-width: 0;
  }

  .blog-index-header {
    display: grid;
    gap: 1rem;
  }

  .blog-index-header h1 {
    margin: 0;
  }

  .blog-intro {
    max-width: none;
  }

  .blog-index-list {
    display: grid;
    gap: 2.5rem;
  }

  .blog-card {
    display: grid;
    gap: 1.2rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(120, 120, 120, 0.14);
  }

  .blog-card-image {
    display: block;
  }

  .blog-card-image img {
    display: block;
    width: 100%;
    max-height: 24rem;
    object-fit: cover;
  }

  .blog-card-copy {
    display: grid;
    gap: 0.75rem;
    color: var(--page-copy-color);
  }

  .blog-card-date {
    margin: 0;
    font-family: var(--font-ui);
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    color: var(--page-muted-color);
  }

  .blog-card-copy h2 {
    margin: 0;
  }

  .blog-card-copy h2 a {
    color: inherit;
    text-decoration: none;
  }

  .blog-card-copy h2 a:hover,
  .blog-card-copy h2 a:focus-visible {
    text-decoration: underline;
  }

  .blog-card-copy p {
    margin: 0;
  }

  .read-more {
    color: #6f8b1d;
    font-weight: 700;
    text-decoration: none;
  }

  .read-more:hover,
  .read-more:focus-visible {
    text-decoration: underline;
  }

  @media (max-width: 72rem) {
    .blog-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding-inline: var(--site-inner-padding);
    }
  }
</style>
