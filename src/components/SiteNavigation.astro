---
import { withBase } from "../lib/urls.mjs";

const { items = [], currentPath = "/" } = Astro.props;
const basePath = import.meta.env.BASE_URL;

const isActive = (href) => {
  if (href === "/") {
    return currentPath === "/";
  }

  return currentPath === href || currentPath.startsWith(href);
};

const hasActiveChild = (item) => item.children?.some((child) => isActive(child.href)) ?? false;
---

<nav class="site-nav" aria-label="Primary">
  <ul class="nav-list">
    {items.map((item, index) => {
      const itemHasChildren = item.children?.length;
      const itemHasActiveChild = hasActiveChild(item);
      const submenuId = `nav-submenu-${index}`;

      return (
        <li class:list={["nav-item", { "has-children": itemHasChildren, "is-open": itemHasActiveChild }]}>
          <div class="nav-link-row">
            <a href={withBase(item.href, basePath)} aria-current={isActive(item.href) ? "page" : undefined}>
              {item.label}
            </a>

            {
              itemHasChildren ? (
                <button
                  type="button"
                  class="sub-menu-toggle"
                  aria-expanded={itemHasActiveChild ? "true" : "false"}
                  aria-controls={submenuId}
                  aria-label={`Toggle ${item.label} submenu`}
                >
                  <span aria-hidden="true">+</span>
                </button>
              ) : null
            }
          </div>

          {
            itemHasChildren ? (
              <ul id={submenuId} class="sub-menu" aria-label={`${item.label} sections`}>
                {item.children.map((child) => (
                  <li>
                    <a href={withBase(child.href, basePath)} aria-current={isActive(child.href) ? "page" : undefined}>
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            ) : null
          }
        </li>
      );
    })}
  </ul>
</nav>

<script is:inline>
  (() => {
    const nav = document.currentScript?.previousElementSibling;
    if (!(nav instanceof HTMLElement)) {
      return;
    }

    const mediaQuery = window.matchMedia("(max-width: 44rem)");

    nav.querySelectorAll(".sub-menu-toggle").forEach((toggle) => {
      toggle.addEventListener("click", () => {
        if (!mediaQuery.matches) {
          return;
        }

        const item = toggle.closest(".nav-item");
        if (!(item instanceof HTMLElement)) {
          return;
        }

        const nextState = !item.classList.contains("is-open");
        item.classList.toggle("is-open", nextState);
        toggle.setAttribute("aria-expanded", nextState ? "true" : "false");
      });
    });

    mediaQuery.addEventListener("change", (event) => {
      if (event.matches) {
        return;
      }

      nav.querySelectorAll(".nav-item.is-open").forEach((item) => {
        if (!(item instanceof HTMLElement) || item.querySelector('a[aria-current="page"]')) {
          return;
        }

        item.classList.remove("is-open");
        const toggle = item.querySelector(".sub-menu-toggle");
        if (toggle instanceof HTMLElement) {
          toggle.setAttribute("aria-expanded", "false");
        }
      });
    });
  })();
</script>

<style>
  .site-nav {
    display: flex;
    justify-content: center;
  }

  .nav-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link-row {
    display: flex;
    align-items: stretch;
  }

  .nav-item + .nav-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: 1px;
    height: 0.95rem;
    transform: translateY(-50%);
    background: rgba(202, 222, 134, 0.78);
  }

  .nav-list > li > .nav-link-row > a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.25rem;
    padding: 0.12rem 0.75rem;
    color: var(--site-nav-text);
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: 0.79rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: color 160ms ease, text-decoration-color 160ms ease;
    white-space: nowrap;
  }

  .nav-list > li > .nav-link-row > a:hover,
  .nav-list > li > .nav-link-row > a:focus-visible,
  .nav-list > li > .nav-link-row > a[aria-current="page"] {
    color: var(--site-nav-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18rem;
  }

  .sub-menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    min-height: 2.25rem;
    padding: 0.12rem 0.55rem;
    border: 0;
    background: transparent;
    color: var(--site-nav-text);
    font: inherit;
    cursor: pointer;
  }

  .sub-menu-toggle:hover,
  .sub-menu-toggle:focus-visible {
    color: var(--site-nav-accent);
  }

  .sub-menu {
    position: absolute;
    left: 50%;
    top: calc(100% + 0.1rem);
    transform: translateX(-50%);
    list-style: none;
    margin: 0;
    padding: 0.35rem 0;
    min-width: 12rem;
    background: #f8f4e9;
    border: 1px solid rgba(132, 150, 71, 0.26);
    box-shadow: 0 16px 24px rgba(45, 56, 32, 0.12);
    display: block;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: 5;
    transition: opacity 140ms ease;
  }

  .has-children:hover .sub-menu,
  .has-children:focus-within .sub-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .sub-menu a {
    display: block;
    padding: 0.45rem 1rem;
    color: #444444;
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: 0.84rem;
  }

  .sub-menu a:hover,
  .sub-menu a:focus-visible,
  .sub-menu a[aria-current="page"] {
    background: rgba(167, 201, 54, 0.2);
    color: var(--site-nav-accent);
  }

  @media (max-width: 44rem) {
    .nav-list {
      display: grid;
      width: 100%;
      gap: 0;
    }

    .nav-item + .nav-item::before {
      display: none;
    }

    .nav-item {
      width: 100%;
      border-top: 1px solid rgba(202, 222, 134, 0.5);
    }

    .nav-list > .nav-item:first-child {
      border-top: 0;
    }

    .nav-link-row {
      width: 100%;
    }

    .nav-list > li > .nav-link-row > a {
      min-height: 2rem;
      flex: 1 1 auto;
      justify-content: flex-start;
      padding: 0.7rem 0.85rem;
      font-size: 0.76rem;
      text-align: left;
      white-space: normal;
    }

    .sub-menu-toggle {
      display: inline-flex;
      flex: 0 0 auto;
      min-height: 2rem;
      padding: 0.7rem 0.85rem;
      font-size: 0.85rem;
      font-weight: 700;
    }

    .sub-menu {
      position: static;
      transform: none;
      min-width: 0;
      margin-top: 0.15rem;
      padding: 0.2rem 0;
      box-shadow: none;
      border-inline: 0;
      border-bottom: 0;
      background: rgba(248, 244, 233, 0.78);
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      display: none;
    }

    .nav-item.is-open .sub-menu {
      display: block;
    }

    .nav-item.is-open .sub-menu-toggle span {
      transform: rotate(45deg);
    }

    .sub-menu a {
      padding: 0.55rem 1rem;
      font-size: 0.8rem;
      text-align: left;
    }
  }
</style>
